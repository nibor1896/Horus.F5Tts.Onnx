# Local model files (large; downloaded separately, see README). Scoped to a models/
# folder on purpose — a bare "*.onnx" would also match the "Horus.F5Tts.Onnx" project
# directory (case-insensitive on Windows) and ignore the whole source tree.
models/
**/models/*.onnx
